# Database - PostgreSQL
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/hidup_produktif?schema=public"

# Session secret (WAJIB di production, min 32 karakter)
SESSION_SECRET="change-this-to-random-string-min-32-chars"

# Telegram Bot (optional - for daily notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Node environment
NODE_ENV=production

# Seed user (opsional, untuk initial user saat first run)
SEED_USERNAME="admin"
SEED_PASSWORD="***"
SEED_NAME="Admin"
